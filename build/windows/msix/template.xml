<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="kutyaguru-booking.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Kutyaguru\Kutyaguru Booking">
    </Installer>
    <PackageInformation
        PackageName="hu.kutyaguru.booking"
        PackageDisplayName="Kutyaguru Booking"
        PublisherName="CN=Kutyaguru"
        PublisherDisplayName="Kutyaguru"
        Version="0.1.0.0"
        PackageDescription="Booked4us → Számlázz.hu CSV converter">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="kutyagurubooking"
                Description="Booked4us → Számlázz.hu CSV converter"
                DisplayName="Kutyaguru Booking"
                ExecutableName="kutyaguru-booking.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Kutyaguru Booking</DisplayName>
            <PublisherDisplayName>Kutyaguru</PublisherDisplayName>
            <Description>Booked4us → Számlázz.hu CSV converter</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="kutyaguru-booking.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
